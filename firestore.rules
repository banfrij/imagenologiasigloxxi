rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function hasAllowedEmail() {
      return request.auth.token.email != null
        && request.auth.token.email in [
          'alamosxxi@gmail.com',
          'sanfexxi@gmail.com',
          'alamos04u@gmail.com',
          'alamos01m@gmail.com',
          'alamos02m@gmail.com',
          'alamos03t@gmail.com',
          'sanfe01f@gmail.com'
        ];
    }

    function isSignedIn() {
      return request.auth != null && hasAllowedEmail();
    }

    function userEmail() {
      return request.auth.token.email.lower();
    }

    function isCrossBranchAdmin() {
      return userEmail() in [
        'alamosxxi@gmail.com',
        'sanfexxi@gmail.com'
      ];
    }

    function canAccessBranch(branch) {
      return isCrossBranchAdmin()
        || (
          branch == 'Alamos'
          && userEmail() in [
            'alamos04u@gmail.com',
            'alamos01m@gmail.com',
            'alamos02m@gmail.com',
            'alamos03t@gmail.com'
          ]
        )
        || (
          branch == 'San Felipe'
          && userEmail() in [
            'sanfe01f@gmail.com'
          ]
        );
    }

    function isNonEmptyString(value) {
      return value is string && value != '';
    }

    function validateAuditFields(data) {
      return data.keys().hasAll([
          'createdBy',
          'createdAt',
          'updatedBy',
          'updatedAt'
        ])
        && isNonEmptyString(data.createdBy)
        && isNonEmptyString(data.createdAt)
        && isNonEmptyString(data.updatedBy)
        && isNonEmptyString(data.updatedAt);
    }

    match /appointments/{appointmentId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && validateAppointment(request.resource.data);
      allow delete: if isSignedIn();
    }

    match /appointment_cancellations/{eventId} {
      allow read, create: if isSignedIn() && validateCancellation(request.resource.data);
      allow update, delete: if false;
    }

    match /appointment_audit/{eventId} {
      allow read, create: if isSignedIn() && validateAppointmentAudit(request.resource.data);
      allow update, delete: if false;
    }

    match /agenda_color_marks/{markId} {
      allow read: if isSignedIn() && canAccessBranch(resource.data.branch);
      allow create, update: if isSignedIn()
        && validateColorMark(request.resource.data)
        && canAccessBranch(request.resource.data.branch)
        && request.resource.data.createdBy == request.auth.token.email
        && request.resource.id == buildColorMarkId(
          request.resource.data.date,
          request.resource.data.branch,
          request.resource.data.column,
          request.resource.data.time
        );
      allow delete: if isSignedIn() && canAccessBranch(resource.data.branch);
    }

    function validateAppointment(data) {
      return data is map
        && data.keys().hasAll([
          'id',
          'time',
          'date',
          'technique',
          'study',
          'duration',
          'patient',
          'age',
          'number',
          'doctor',
          'branch',
          'ambulance',
          'sedation',
          'oxygen',
          'noteTitle',
          'observation',
          'startTimeMinutes',
          'endTimeMinutes'
        ])
        && data.id is int
        && data.time is string && data.time != ''
        && data.date is string && data.date != ''
        && data.technique is string && data.technique != ''
        && data.study is string && data.study != ''
        && data.duration is string && data.duration != ''
        && data.patient is string && data.patient != ''
        && data.age is string && data.age != ''
        && data.number is string && data.number != ''
        && data.doctor is string && data.doctor != ''
        && data.branch is string && data.branch != ''
        && data.ambulance is bool
        && data.sedation is bool
        && data.oxygen is bool
        && data.noteTitle is string && data.noteTitle != ''
        && data.observation is string && data.observation != ''
        && data.startTimeMinutes is int
        && data.endTimeMinutes is int
        && data.startTimeMinutes >= 0
        && data.endTimeMinutes > data.startTimeMinutes
        && validateAuditFields(data);
    }

    function validateCancellation(data) {
      return data is map
        && data.keys().hasAll([
          'appointmentId',
          'patient',
          'branch',
          'technique',
          'date',
          'time',
          'reason',
          'cancelledBy',
          'cancelledAt'
        ])
        && data.appointmentId is int
        && isNonEmptyString(data.patient)
        && isNonEmptyString(data.branch)
        && isNonEmptyString(data.technique)
        && isNonEmptyString(data.date)
        && isNonEmptyString(data.time)
        && isNonEmptyString(data.reason)
        && isNonEmptyString(data.cancelledBy)
        && isNonEmptyString(data.cancelledAt);
    }

    function validateAppointmentAudit(data) {
      return data is map
        && data.keys().hasAll([
          'action',
          'user',
          'idEstudio',
          'study',
          'patient',
          'branch',
          'date',
          'time',
          'createdAt'
        ])
        && (data.action == 'AGENDO' || data.action == 'CANCELO')
        && isNonEmptyString(data.user)
        && data.idEstudio is int
        && isNonEmptyString(data.study)
        && isNonEmptyString(data.patient)
        && isNonEmptyString(data.branch)
        && isNonEmptyString(data.date)
        && isNonEmptyString(data.time)
        && (data.reason == null || isNonEmptyString(data.reason))
        && isNonEmptyString(data.createdAt);
    }

    function buildColorMarkId(date, branch, column, time) {
      return date + '_' + branch + '_' + column + '_' + time;
    }

    function validateColorMark(data) {
      return data is map
        && data.keys().hasAll([
          'id',
          'date',
          'branch',
          'column',
          'time',
          'color',
          'colorLabel',
          'note',
          'createdBy',
          'createdAt'
        ])
        && isNonEmptyString(data.id)
        && isNonEmptyString(data.date)
        && (data.branch == 'Alamos' || data.branch == 'San Felipe')
        && (data.column == 'RM' || data.column == 'TC' || data.column == 'RXUSG')
        && isNonEmptyString(data.time)
        && isNonEmptyString(data.color)
        && isNonEmptyString(data.colorLabel)
        && isNonEmptyString(data.note)
        && isNonEmptyString(data.createdBy)
        && isNonEmptyString(data.createdAt)
        && data.id == buildColorMarkId(data.date, data.branch, data.column, data.time);
    }
  }
}